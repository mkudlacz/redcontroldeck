---
layout: base.njk
pageTitle: Writing — Redcontroldeck
---

<div class="page-header container">
  <h1>WRITING</h1>
</div>

<div class="writing-index container">
  {% if collections.posts.length > 0 %}
  <div class="writing-group">
    <h2>Posts</h2>
    {% for post in collections.posts %}
    <div class="writing-entry">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      <div class="entry-meta">{{ post.date | formatDate }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if collections.essays.length > 0 %}
  <div class="writing-group">
    <h2>Essays</h2>
    {% for essay in collections.essays %}
    <div class="writing-entry">
      <a href="{{ essay.url }}">{{ essay.data.title }}</a>
    </div>
    {% endfor %}
  </div>
  {% endif %}
</div>
