---
layout: base.njk
---
<div class="post container">
  <a href="/writing/" class="back-link">← Writing</a>
  <header class="post-header">
    {% if hero %}
    <img src="{{ hero }}" alt="" class="post-hero" />
    {% endif %}
    {% if series %}
    <div class="post-series">{{ series }}</div>
    {% endif %}
    <h1 class="post-title">{{ title }}{% if youtube %}<a href="{{ youtube }}" class="post-title-link" target="_blank" rel="noopener" aria-label="Listen on YouTube">↗</a>{% endif %}</h1>
    {% if date %}
    <div class="post-meta">{{ date | formatDate }}</div>
    {% endif %}
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if series %}
  {% set prevChapter = collections.essays | prevInSeries(series, page.url) %}
  {% set nextChapter = collections.essays | nextInSeries(series, page.url) %}
  {% if prevChapter or nextChapter %}
  <nav class="series-nav">
    {% if prevChapter %}
    <a href="{{ prevChapter.url }}" class="series-prev">← {{ prevChapter.data.title }}</a>
    {% endif %}
    {% if nextChapter %}
    <a href="{{ nextChapter.url }}" class="series-next">{{ nextChapter.data.title }} →</a>
    {% endif %}
  </nav>
  {% endif %}
  {% endif %}
</div>
